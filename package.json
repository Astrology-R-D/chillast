{
  "name": "chillast",
  "version": "0.0.2",
  "description": "CHILLAST — a professional desktop astrology studio for natal, transit, synastry and composite charts.",
  "author": "CHILLAST",
  "license": "MIT",
  "main": "src/main/Main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "test": "node tests/RunAll.js",
    "smoke": "node tests/SmokeRenderer.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.chillast.astrology",
    "productName": "CHILLAST",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "circular-natal-horoscope-js": "^1.1.0",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "electron": "^42.4.1"
  }
}
